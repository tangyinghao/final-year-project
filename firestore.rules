rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isParticipant(chatData) {
      return isAuth() && request.auth.uid in chatData.participants;
    }
    function validGradYear() {
      let y = request.resource.data.graduationYear;
      let currentYear = request.time.toMillis() / 31536000000 + 1970;
      return y == null || (y is int && y >= 1991 && y <= currentYear + 6);
    }

    // ── users/{uid} ─────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid) && validGradYear();
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'status', 'uid', 'email', 'createdAt'])
        && validGradYear();
      allow delete: if false;

      // savedItems subcollection
      match /savedItems/{itemId} {
        allow read, write: if isOwner(uid);
      }

      // footprint subcollection
      match /footprint/{zoneId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── cohorts/{year} ──────────────────────────────────────────────
    match /cohorts/{year} {
      allow read: if isAuth();
      allow create, update, delete: if false; // backend-managed only
    }

    // ── chats/{chatId} ──────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.type in ['direct', 'group'];
      allow update: if isAuth()
        && request.auth.uid in resource.data.participants
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['type', 'cohortYear']);
      allow delete: if false;

      // messages subcollection
      match /messages/{messageId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── events/{eventId} ────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuth()
        && (resource.data.status == 'approved' || resource.data.createdBy == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.type == 'user-created'
        && request.resource.data.status == 'pending'
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth()
        && resource.data.createdBy == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['type', 'status']);
      // Allow any authenticated user to join/leave (attendees + attendeeCount only)
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['attendees', 'attendeeCount', 'updatedAt']);
      allow delete: if false;
    }

    // ── jobs/{jobId} ────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if isAuth()
        && (resource.data.status == 'approved' || resource.data.postedBy == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.status == 'pending'
        && request.resource.data.postedBy == request.auth.uid;
      allow update: if isAuth()
        && resource.data.postedBy == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status']);
      allow delete: if false;

      // applications subcollection
      match /applications/{applicantId} {
        allow read: if isAuth()
          && (request.auth.uid == applicantId
              || request.auth.uid == get(/databases/$(database)/documents/jobs/$(jobId)).data.postedBy);
        allow create: if isAuth() && request.auth.uid == applicantId;
        allow update, delete: if false;
      }
    }

    // ── mentorships/{mentorshipId} ──────────────────────────────────
    match /mentorships/{mentorshipId} {
      allow read: if isAuth()
        && (resource.data.status == 'approved' || resource.data.mentorId == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.status == 'pending'
        && request.resource.data.mentorId == request.auth.uid;
      allow update: if isAuth()
        && resource.data.mentorId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status']);
      allow delete: if false;

      // requests subcollection
      match /requests/{requesterId} {
        allow read: if isAuth()
          && (request.auth.uid == requesterId
              || request.auth.uid == get(/databases/$(database)/documents/mentorships/$(mentorshipId)).data.mentorId);
        allow create: if isAuth() && request.auth.uid == requesterId;
        allow update, delete: if false;
      }
    }

    // ── reports/{reportId} ──────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if false; // admin reads via backend/admin SDK
      allow create: if isAuth()
        && request.resource.data.reportedBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── notifications/{notifId} ─────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if false; // backend only
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }
  }
}
